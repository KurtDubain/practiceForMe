{
  "logging": {
    "level": "info"
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789
  },
  "agents": {
    "defaults": {
      "workspace": "__WORKSPACE__",
      "skipBootstrap": true,
      "model": {
        "primary": "openai/gpt-5.4"
      },
      "thinkingDefault": "high",
      "timeoutSeconds": 1800,
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": [
        "@openclaw",
        "openclaw"
      ]
    }
  },
  "session": {
    "scope": "per-sender",
    "resetTriggers": [
      "/new",
      "/reset"
    ],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 10080
    }
  }
}
