{
  "logging": {
    "level": "info"
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789
  },
  "agents": {
    "defaults": {
      "workspace": "__WORKSPACE__",
      "skipBootstrap": true,
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "thinkingDefault": "high",
      "timeoutSeconds": 1800,
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": [
        "@openclaw",
        "openclaw"
      ]
    }
  },
  "session": {
    "scope": "per-sender",
    "resetTriggers": [
      "/new",
      "/reset"
    ],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 10080
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "codex-bridge",
      "device-pair",
      "memory-core",
      "ollama",
      "phone-control",
      "sglang",
      "talk-voice",
      "vllm"
    ],
    "load": {
      "paths": [
        "__CODEX_PLUGIN__"
      ]
    },
    "entries": {
      "codex-bridge": {
        "enabled": true,
        "config": {
          "repoRoot": "__REPO_ROOT__",
          "codexBin": "codex",
          "defaultSandbox": "read-only",
          "reasoningEffort": "medium",
          "timeoutMs": 900000,
          "maxOutputChars": 12000
        }
      }
    }
  }
}
